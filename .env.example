# ---------------------------------------------------------------------------
# Prompt Injection Detector — example environment file.
# Copy to `.env` and fill in real values. `.env` is gitignored; never commit it.
# ---------------------------------------------------------------------------

# --- Service ---
ENVIRONMENT=development

# --- LLM classifier: primary provider (OpenAI) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# --- LLM classifier: fallback provider (OpenRouter) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Master switch for the classifier layer (heuristics-only when false).
CLASSIFIER_ENABLED=true
CLASSIFIER_TIMEOUT_S=8.0

# --- Detection thresholds (heuristic score in [0,1]) ---
HEURISTIC_HIGH_THRESHOLD=0.80
HEURISTIC_LOW_THRESHOLD=0.20
MALICIOUS_THRESHOLD=0.70
SUSPICIOUS_THRESHOLD=0.40
CLASSIFIER_WEIGHT=0.65

# --- Database / logging ---
# In docker-compose the host is `db`; for local runs use `localhost`.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pid
LOGGING_ENABLED=true
INPUT_PREVIEW_CHARS=500
