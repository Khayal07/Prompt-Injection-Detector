# ---------------------------------------------------------------------------
# Prompt Injection Detector — example environment file.
# Copy to `.env` and fill in real values. `.env` is gitignored; never commit it.
# ---------------------------------------------------------------------------

# --- Service ---
ENVIRONMENT=development

# --- LLM classifier: primary provider (OpenAI) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# --- LLM classifier: fallback provider (OpenRouter) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Master switch for the classifier layer (heuristics-only when false).
CLASSIFIER_ENABLED=true
CLASSIFIER_TIMEOUT_S=8.0

# --- Detection thresholds (heuristic score in [0,1]) ---
HEURISTIC_HIGH_THRESHOLD=0.80
HEURISTIC_LOW_THRESHOLD=0.20
MALICIOUS_THRESHOLD=0.70
SUSPICIOUS_THRESHOLD=0.40
CLASSIFIER_WEIGHT=0.65

# --- Database / logging ---
# In docker-compose the host is `db`; for local runs use `localhost`.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pid
LOGGING_ENABLED=true
INPUT_PREVIEW_CHARS=500

# --- API security (all opt-in) ---
# Comma-separated API keys. When set, /check and /admin require `X-API-Key`.
# Leave empty to disable auth (local dev). Generate one with e.g. `openssl rand -hex 32`.
API_KEYS=
# Per-client rate limit (slowapi syntax). Empty disables limiting.
RATE_LIMIT=60/minute
# Rate-limit counter storage. Use redis://host:6379 to share limits across workers/instances.
RATE_LIMIT_STORAGE_URI=memory://
# Reject inputs longer than this many characters (0 = no limit).
MAX_INPUT_CHARS=20000
# Comma-separated allowed CORS origins (e.g. https://app.example.com). Empty = none.
CORS_ORIGINS=

# --- Operations ---
LOG_LEVEL=INFO
JSON_LOGS=true
METRICS_ENABLED=true
# Auto-reload config/rules.yaml when it changes on disk (works across workers).
RULES_AUTORELOAD=false
# Gunicorn worker processes (production server).
WEB_CONCURRENCY=2
